# ── Required ──────────────────────────────────────────────────────────────────
# LAN IP of the machine running this Docker (used for TLS cert SAN + RTP)
ASTERISK_IP=192.168.0.111

# ── PostgreSQL ────────────────────────────────────────────────────────────────
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DB=asterisk_cdr
PG_USER=asterisk
PG_PASSWORD=asterisk123

# ── Asterisk AMI ──────────────────────────────────────────────────────────────
AMI_SECRET=tayyab

# ── Asterisk ARI ──────────────────────────────────────────────────────────────
ARI_PASSWORD=crm_ari_pass123

# ── CORS — frontend origins allowed to connect ────────────────────────────────
# Comma separated, no spaces
ALLOWED_ORIGINS=http://localhost:3000,https://app.leadspoint.in

# ── SSH Tunnel to AWS (optional) ──────────────────────────────────────────────
# Only needed if Django backend is on AWS and needs to reach local PostgreSQL/AMI
# To enable: docker compose --profile tunnel up -d
AWS_HOST=13.203.77.44
AWS_USER=ubuntu
AWS_KEY_PATH=/home/desmond/Downloads/CRMkey.pem
TUNNEL_PG_PORT=15432
TUNNEL_AMI_PORT=15038
